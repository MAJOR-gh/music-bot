# Токен бота из Discord Developer Portal (ОБЯЗАТЕЛЬНО)
DISCORD_TOKEN=your_bot_token_here

# ID твоего сервера для мгновенной синхронизации команд (опционально).
# Если оставить пустым — команды синхронизируются глобально (до ~1 часа).
GUILD_ID=

# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Через сколько секунд бездействия бот сам отключается (по умолчанию 300 = 5 минут)
IDLE_TIMEOUT=300

# Сколько вариантов показывать при текстовом поиске /play (по умолчанию 25).
# Список листается по 10 штук на страницу кнопками ◀▶.
SEARCH_RESULTS=25
